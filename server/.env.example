# Copy to server/.env and adjust.
PORT=3000
NODE_ENV=development

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=pritesh_photography

# Used to sign admin JWT tokens (set a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Default admin created by seed (change password after first login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Allowed browser origins (comma-separated). Include main site + admin dev ports.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
